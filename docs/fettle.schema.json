                    "LR002_NEW_ABSTRACTION_NAME": {
                      "type": "boolean",
                      "default": true
                    },
                    "LR003_PASS_THROUGH_WRAPPER": {
                      "type": "boolean",
                      "default": true
                    },
                    "LR004_SINGLE_METHOD_CLASS": {
                      "type": "boolean",
                      "default": true
                    },
                    "LR008_LARGE_ADDITION": {
                      "type": "boolean",
                      "default": true
                    },
                    "LR012_DUPLICATE_LOCAL_HELPER_NAME": {
                      "type": "boolean",
                      "default": true
