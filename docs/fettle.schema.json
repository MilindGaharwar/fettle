                "commit",
                "enforce",
                "manifest",
                "marker",
                "none",
                "off",
                "silent",
                "soft",
                "strict"
              ]
            }
          },
          "additionalProperties": false
        },
        "cross_file": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
